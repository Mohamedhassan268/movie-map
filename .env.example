# Copy to .env.local (gitignored) and fill in — never commit real values.

# TMDB — set ONE (Vercel env for the live app; local shell for the offline pipeline)
TMDB_READ_TOKEN=
TMDB_API_KEY=

# Serper — only needed by scraper/serper_gapfill.py
SERPER_API_KEY=

# Gemini — free-tier text embeddings for plot/theme similarity (Vercel env
# for the live app's /api/embed; local shell for similarity/embed_catalog.py).
# Get a key at aistudio.google.com/apikey.
GEMINI_API_KEY=

# Supabase (free tier, no credit card needed) — used by api/embed.js as a
# shared cache for embeddings across all visitors. Create a project at
# supabase.com, then Settings > API for the URL and service_role key.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional: lock the /api/tmdb and /api/embed proxies to your site's origin
# (see api/tmdb.js). Leave empty to allow all origins (default).
ALLOWED_ORIGIN=
