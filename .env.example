# Copy to .env.local (gitignored) and fill in — never commit real values.

# TMDB — set ONE (Vercel env for the live app; local shell for the offline pipeline)
TMDB_READ_TOKEN=
TMDB_API_KEY=

# Serper — only needed by scraper/serper_gapfill.py
SERPER_API_KEY=

# Optional: lock the /api/tmdb proxy to your site's origin (see api/tmdb.js).
# Leave empty to allow all origins (default).
ALLOWED_ORIGIN=
